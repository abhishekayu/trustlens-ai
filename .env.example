# TrustLens AI Configuration
# Copy to .env and fill in values

# ── Server ──────────────────────────────────────────
TRUSTLENS_HOST=0.0.0.0
TRUSTLENS_PORT=8000
TRUSTLENS_LOG_LEVEL=info
TRUSTLENS_DEBUG=false

# ── Database ────────────────────────────────────────
TRUSTLENS_DB_URL=sqlite+aiosqlite:///./trustlens.db

# ── AI Providers (set at least one) ─────────────────
TRUSTLENS_AI_PROVIDER=ollama

# Ollama (local, default)
TRUSTLENS_OLLAMA_BASE_URL=http://localhost:11434
TRUSTLENS_OLLAMA_MODEL=llama3

# OpenAI
TRUSTLENS_OPENAI_API_KEY=
TRUSTLENS_OPENAI_MODEL=gpt-4o

# Anthropic
TRUSTLENS_ANTHROPIC_API_KEY=
TRUSTLENS_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Crawler / Security ─────────────────────────────
TRUSTLENS_CRAWLER_TIMEOUT=30
TRUSTLENS_CRAWLER_MAX_REDIRECTS=10
TRUSTLENS_CRAWLER_USER_AGENT=TrustLens/0.1 SecurityScanner
TRUSTLENS_SSRF_BLOCK_PRIVATE=true
TRUSTLENS_SCREENSHOT_ENABLED=true

# ── Rate Limiting ───────────────────────────────────
TRUSTLENS_RATE_LIMIT_REQUESTS=30
TRUSTLENS_RATE_LIMIT_WINDOW_SECONDS=60

# ── Domain Access Control ──────────────────────────
# Comma-separated. Empty = no restriction.
TRUSTLENS_DOMAIN_ALLOWLIST=
TRUSTLENS_DOMAIN_DENYLIST=

# ── Scoring (70/30 hybrid) ─────────────────────────
# Rule-based signals: 70%, AI advisory: 30%
TRUSTLENS_SCORE_WEIGHT_RULES=0.70
TRUSTLENS_SCORE_WEIGHT_AI=0.30

# ── API Key Authentication ─────────────────────────
# Set to true to require API keys for all endpoints
TRUSTLENS_API_KEY_REQUIRED=false
TRUSTLENS_API_KEY_HEADER=X-API-Key

# ── Threat Intelligence Feeds ──────────────────────
# Comma-separated feed URLs to auto-ingest at startup
TRUSTLENS_THREAT_FEED_URLS=
TRUSTLENS_THREAT_FEED_REFRESH_HOURS=6

# ── Screenshot Similarity ──────────────────────────
TRUSTLENS_SCREENSHOT_SIMILARITY_THRESHOLD=0.85
TRUSTLENS_SCREENSHOT_HASH_ALGORITHM=phash

# ── Community Reporting ────────────────────────────
TRUSTLENS_COMMUNITY_REPORTS_ENABLED=true
TRUSTLENS_COMMUNITY_REPORT_MIN_TRUST=0.1

# ── Enterprise Mode ────────────────────────────────
TRUSTLENS_ENTERPRISE_MODE=false
TRUSTLENS_ENTERPRISE_BRAND_SCAN_INTERVAL=3600

# ── Observability / Audit ──────────────────────────
TRUSTLENS_AUDIT_LOG_ENABLED=true
TRUSTLENS_SUSPICIOUS_ACTIVITY_THRESHOLD=50
